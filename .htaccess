# Configuração mínima para servidores gratuitos
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Detecta HTTPS em servidores com proxy (Ezyro/InfinityFree)
    # Isso ajuda o PHP a saber que o site está em modo seguro
    SetEnvIf X-Forwarded-Proto https HTTPS=on

    # Força HTTPS (Ativado a pedido do usuário)
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Se o erro 500 persistir, comente a linha abaixo colocando um # na frente
    RewriteRule ^src/.*$ - [F,L]
</IfModule>